{
  "manifest_version": 3,
  "name": "Meeting Time Tracker",
  "version": "2.0.0",
  "description": "Asks whether to track a call, names it, records join/leave times, and appends them to your Google Sheet.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meeting Time Tracker"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*", "https://*.zoom.us/wc/*"],
      "js": ["modal.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
